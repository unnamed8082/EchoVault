# EchoVault 环境变量
# 复制此文件为 .env 并填入实际值

# ============================================
# 安全密钥（必须修改，不能使用默认值）
# ============================================
# JWT Token 签名密钥，生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# 数据加密密钥（Fernet），生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_KEY=change-me-in-production

# ============================================
# 数据库配置
# ============================================
# SQLite 本地存储（默认，无需额外配置）
DATABASE_URL=sqlite+aiosqlite:///./data/echovault.db

# ============================================
# 服务器配置
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# CORS 允许的源，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# 前端配置
# ============================================
# Next.js 公开 API 地址（浏览器可访问的地址）
NEXT_PUBLIC_API_URL=http://localhost:9000
# Next.js 运行环境: development, production
NODE_ENV=development
