# EchoVault 环境变量
# 复制此文件为 .env 并填入实际值

# ============================================
# 安全密钥（必须修改，不能使用默认值）
# ============================================
# JWT Token 签名密钥，生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# 数据加密密钥（Fernet），生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_KEY=change-me-in-production

# ============================================
# 数据库配置
# ============================================
# SQLite 本地存储（默认，无需额外配置）
DATABASE_URL=sqlite+aiosqlite:///./data/echovault.db

# Turso 数据库（生产环境推荐）
# 获取方式：https://turso.tech
# 1. 安装 Turso CLI: curl -sSfL https://get.tur.so/install.sh | bash
# 2. 登录: turso auth login
# 3. 创建数据库: turso db create echovault
# 4. 获取 URL: turso db show echovault --url
# 5. 创建 Token: turso db tokens create echovault
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# 本地嵌入式副本路径（可选，留空使用内存模式）
TURSO_LOCAL_DB=

# ============================================
# 服务器配置
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# CORS 允许的源，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# 前端配置
# ============================================
# Next.js 公开 API 地址（浏览器可访问的地址）
NEXT_PUBLIC_API_URL=http://localhost:9000
# Next.js 运行环境: development, production
NODE_ENV=development
