# ===========================================
# EchoVault Environment Configuration
# ===========================================
# 
# 使用说明：
# 1. 复制此文件为 .env.local (本地开发) 或 .env.production (生产环境)
# 2. 填写真实的 API 密钥和配置值
# 3. 不要将包含真实密钥的文件提交到版本控制
#
# 安全提示：
# - 所有敏感信息使用环境变量存储
# - 生产环境建议使用密钥管理服务 (AWS KMS, Azure Key Vault 等)
# - 定期轮换 API 密钥
# ===========================================

# ===========================================
# 应用基础配置
# ===========================================
NEXT_PUBLIC_APP_NAME=EchoVault
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=development

# ===========================================
# AI 服务配置 - OpenAI
# ===========================================
# 获取 API Key: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=${OPENAI_API_KEY}
NEXT_PUBLIC_OPENAI_BASE_URL=https://api.openai.com/v1
NEXT_PUBLIC_OPENAI_MODEL=gpt-4o-mini

# 备选模型（可选）
# NEXT_PUBLIC_OPENAI_MODEL_FALLBACK=gpt-4o
# NEXT_PUBLIC_OPENAI_MODEL_FAST=gpt-4o-mini

# ===========================================
# AI 服务配置 - DeepSeek
# ===========================================
# 获取 API Key: https://platform.deepseek.com/
NEXT_PUBLIC_DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
NEXT_PUBLIC_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
NEXT_PUBLIC_DEEPSEEK_MODEL=deepseek-chat

# ===========================================
# AI 服务配置 - Anthropic Claude (可选)
# ===========================================
# 获取 API Key: https://console.anthropic.com/
NEXT_PUBLIC_ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
NEXT_PUBLIC_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
NEXT_PUBLIC_ANTHROPIC_MODEL=claude-opus-4-7

# ===========================================
# AI 提供商选择与回退
# ===========================================
# 默认使用的 AI 提供商 (openai | deepseek | anthropic)
NEXT_PUBLIC_AI_PROVIDER=openai

# 当主提供商失败时的回退提供商
NEXT_PUBLIC_AI_FALLBACK=deepseek

# 是否启用自动回退 (true | false)
NEXT_PUBLIC_AI_ENABLE_FALLBACK=true

# API 代理地址（用于解决 CORS 问题，部署到摩搭平台时通常需要）
# 本地开发：留空或设置为 http://localhost:9000/api/proxy
# 摩搭平台：设置为 /api/ai-proxy 或后端提供的代理端点
NEXT_PUBLIC_AI_PROXY_URL=

# ===========================================
# 用户认证配置
# ===========================================
# 会话超时时间（毫秒），默认 1 小时
NEXT_PUBLIC_AUTH_SESSION_TIMEOUT=3600000

# 最大登录尝试次数，超过后锁定账户
NEXT_PUBLIC_AUTH_MAX_ATTEMPTS=5

# 账户锁定时间（毫秒），默认 15 分钟
NEXT_PUBLIC_AUTH_LOCKOUT_DURATION=900000

# 加密密钥（用于加密存储敏感数据）
# ⚠️ 生产环境必须修改为强随机密钥（至少 32 个字符）
# 可以使用命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_ENCRYPTION_KEY=${ENCRYPTION_KEY}

# 代理认证头名称（如果使用反向代理认证）
# NEXT_PUBLIC_PROXY_AUTH_HEADER=X-Proxy-Auth

# ===========================================
# 云端同步配置
# ===========================================
# 同步服务端点
# 本地开发: http://localhost:9000/api/sync
# 摩搭平台: /api/sync 或实际的云端同步服务 URL
NEXT_PUBLIC_SYNC_ENDPOINT=/api/sync

# 冲突解决策略:
# - last-write-wins: 最后写入的数据优先（默认）
# - first-write-wins: 最先写入的数据优先
# - manual: 手动解决冲突
# - custom: 使用自定义合并逻辑
NEXT_PUBLIC_SYNC_CONFLICT_STRATEGY=last-write-wins

# 自动同步间隔（毫秒），默认 60 秒，设为 0 禁用自动同步
NEXT_PUBLIC_AUTO_SYNC_INTERVAL=60000

# 是否启用自动同步 (true | false)
NEXT_PUBLIC_ENABLE_AUTO_SYNC=false

# 是否支持离线模式 (true | false)
NEXT_PUBLIC_OFFLINE_SUPPORT=true

# 同步请求超时时间（毫秒）
NEXT_PUBLIC_SYNC_REQUEST_TIMEOUT=30000

# ===========================================
# 技能库配置 (Agent-command & cc-skills)
# ===========================================
# ex-skill GitHub 仓库 URL
NEXT_PUBLIC_EX_SKILL_REPO=https://github.com/therealXiaomanChu/ex-skill

# colleague-skill GitHub 仓库 URL
NEXT_PUBLIC_COLLEAGUE_SKILL_REPO=https://github.com/titanwings/colleague-skill

# 技能缓存 TTL（毫秒），默认 5 分钟
NEXT_PUBLIC_SKILL_CACHE_TTL=300000

# 最大技能执行时间（毫秒）
NEXT_PUBLIC_SKILL_EXECUTION_TIMEOUT=30000

# ===========================================
# 功能开关（用于灰度发布或 A/B 测试）
# ===========================================
# 启用树洞功能 (true | false)
NEXT_PUBLIC_FEATURE_TREEHOLE=true

# 启用 AI 对话功能 (true | false)
NEXT_PUBLIC_FEATURE_AI_CHAT=true

# 启用智能体系统 (true | false)
NEXT_PUBLIC_FEATURE_AGENTS=true

# 启用人格蒸馏功能 (true | false)
NEXT_PUBLIC_FEATURE_DISTILL=true

# 启用云端同步功能 (true | false)
NEXT_PUBLIC_FEATURE_CLOUD_SYNC=false

# ===========================================
# 日志与监控配置
# ===========================================
# 日志级别: debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=info

# 是否启用性能监控 (true | false)
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# 错误上报端点（可选，如 Sentry）
# NEXT_PUBLIC_ERROR_REPORTING_URL=https://sentry.example.com/api/1

# ===========================================
# 平台特定配置
# ===========================================

# [摩搭平台] 特定配置
# 如果在摩搭平台运行，这些变量会自动设置
MODAO_PLATFORM=false
MODAO_WORKSPACE_ID=
MODAO_GATEWAY_URL=

# [本地开发] 特定配置
LOCAL_DEV_MODE=true
LOCAL_BACKEND_URL=http://localhost:9000

# ===========================================
# 高级配置（一般不需要修改）
# ===========================================

# API 请求重试次数
NEXT_PUBLIC_API_MAX_RETRIES=3

# API 重试延迟基数（毫秒）
NEXT_PUBLIC_API_RETRY_DELAY=1000

# 流式响应缓冲区大小
NEXT_PUBLIC_STREAM_BUFFER_SIZE=8192

# 最大上下文窗口（token 数）
NEXT_PUBLIC_MAX_CONTEXT_WINDOW=128000

# 对话历史最大保存条数
MAX_CHAT_HISTORY_LENGTH=1000

# 树洞记录最大保存条数
MAX_TREEHOLE_ENTRIES=500
